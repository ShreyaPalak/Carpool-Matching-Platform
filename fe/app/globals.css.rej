+
+:root {
+  --bg-primary-hex: #0b1020;
+  --bg-secondary-hex: #121a2d;
+  --surface-dark-hex: #1a2338;
+  --border-subtle-hex: #2a3757;
+  --text-primary-hex: #f5f7ff;
+  --text-secondary-hex: #b8c2e0;
+  --brand-600-hex: #2563eb;
+  --accent-cyan-hex: #22d3ee;
+  --success-hex: #22c55e;
+  --shadow-1: 0 2px 8px rgba(0, 0, 0, 0.18);
+  --shadow-2: 0 8px 24px rgba(0, 0, 0, 0.22);
+  --shadow-3: 0 16px 40px rgba(0, 0, 0, 0.28);
+  --ease-standard: cubic-bezier(0.2, 0.8, 0.2, 1);
+  --dur-fast: 150ms;
+  --dur-mid: 220ms;
+  --dur-slow: 280ms;
+}
+
 @layer base {
   * {
     @apply border-border outline-ring/50;
   }
+
   body {
     @apply bg-background text-foreground;
   }
+
+  h1,
+  h2,
+  h3,
+  h4,
+  h5,
+  h6 {
+    font-family: "Sora", "Inter", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
+    letter-spacing: -0.01em;
+  }
 }
